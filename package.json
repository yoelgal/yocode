{
  "name": "yocode",
  "version": "0.1.0",
  "description": "A unified Claude Code workflow tool",
  "type": "module",
  "bin": {
    "yocode": "./bin/yocode.ts"
  },
  "scripts": {
    "build": "bun build ./bin/yocode.ts --outdir dist --target node && cd browse && bun run build",
    "build:cli": "bun build ./bin/yocode.ts --outdir dist --target node",
    "build:browse": "cd browse && bun run build",
    "test": "bun test",
    "dev": "bun run bin/yocode.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest"
  }
}
